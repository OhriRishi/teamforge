# Supabase Configuration
# You can find these values in your Supabase project settings under API

# Your Supabase Project URL
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url

# Your Supabase Anon/Public Key (safe to use in the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Your Supabase Service Role Key (NEVER expose this in the browser, used for server-side admin tasks)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Discord Integration
# Token for the Discord bot to manage channels
DISCORD_BOT_TOKEN=your-discord-bot-token

# FTC Events API (Required for Scouting / Team Lookup features)
FTC_API_USERNAME=your-ftc-username
FTC_API_KEY=your-ftc-api-key
